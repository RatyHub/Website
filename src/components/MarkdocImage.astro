---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';
import { getFormats } from '../getFormats';
interface Props {
  src: ImageMetadata | string;
  alt: string;
}
const { src, alt } = Astro.props;
---

{
  typeof src === 'string' ? (
    <img src={src} alt={alt} />
  ) : (
    <a href={src.src} aria-label="View original image (optional)">
      <Picture src={src} alt={alt} formats={getFormats(src)} layout="full-width" />
    </a>
  )
}

<style>
  img {
    max-width: 100%;
    height: auto;
  }
</style>
