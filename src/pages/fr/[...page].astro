---
import {  render } from 'astro:content';
import Article from '../../layouts/Article.astro';
import { getStaticPagePath } from '../../getStaticPagePaths';
import { getPageEntry } from '../../getPageEntry';
import { indexStore } from '../../components/indexStore';

export const prerender = true;
export const getStaticPaths = getStaticPagePath('fr');

const { entry, subPages, tag } = await getPageEntry(Astro.params.page, 'fr');
if (!entry) {
  return Astro.redirect('/404');
}

indexStore.subPages = subPages;
indexStore.tag = tag;
const { Content } = await render(entry);
const { data } = entry;
---

<Article title={data.title} seoDescription={data.seoDescription} cover={data.cover} tags={data.tags} page={Astro.params.page}>
  <Content frontmatter={data} />
</Article>
